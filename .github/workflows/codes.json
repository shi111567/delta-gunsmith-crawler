name: Daily Gunsmith Crawler

on:
  schedule:
    # 每天 UTC 0:00（北京时间 8:00）自动运行
    - cron: '0 0 * * *'
  # 允许手动触发
  workflow_dispatch:

jobs:
  crawl:
    runs-on: ubuntu-latest
    steps:
      # 1. 检出代码
      - uses: actions/checkout@v4

      # 2. 设置 Node.js 环境
      - uses: actions/setup-node@v4
        with:
          node-version: '20'

      # 3. 安装依赖
      - run: npm install

      # 4. 安装 Playwright 浏览器
      - run: npx playwright install chromium --with-deps

      # 5. 运行爬虫脚本 (会生成 codes.json)
      - name: Run crawler
        run: npm run crawl

      # 6. 提交并推送 codes.json 到仓库
      - name: Commit and push codes.json
        run: |
          git config --global user.name 'github-actions[bot]'
          git config --global user.email 'github-actions[bot]@users.noreply.github.com'
          git add codes.json
          git diff --quiet && git diff --staged --quiet || (git commit -m "🤖 自动更新改枪码 [skip ci]" && git push)
